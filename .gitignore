# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ───────────────────────────────────────────────────────
backend/venv/
venv/
env/
.env

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
backend/.env
*.env

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── ML Model files (large binaries — add to Git LFS if needed) ───────────────
backend/models/*.pkl
backend/models/*.h5
backend/models/*.keras
backend/models/*.pt
backend/models/*.pth

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Kiro spec files (local dev only) ─────────────────────────────────────────
.kiro/

